{
  "info": {
    "name": "Raphael Frame Society API",
    "description": "Import this collection to test all backend APIs. Set {{baseUrl}} to http://localhost:3000 (or your server URL).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "sessionId", "value": "my-session-123" },
    { "key": "userId", "value": "1" },
    { "key": "authToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"name\": \"Admin\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register user (buyer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"name\": \"Jane Buyer\",\n  \"role\": \"buyer\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Register user (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"name\": \"Admin User\",\n  \"role\": \"admin\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "Get me (current user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-id", "value": "{{userId}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Check role",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-id", "value": "{{userId}}" }],
            "url": "{{baseUrl}}/api/users/check-role"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?category=1&minPrice=0&maxPrice=100&sort=price_asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "1", "disabled": true },
                { "key": "minPrice", "value": "0", "disabled": true },
                { "key": "maxPrice", "value": "100", "disabled": true },
                { "key": "sort", "value": "price_asc", "description": "price_asc | price_desc | newest", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/products/1"
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Aurora Frame\",\n  \"description\": \"Beautiful anime-style frame\",\n  \"price\": 49.99,\n  \"images\": [\"/img/aurora1.jpg\"],\n  \"category_id\": 1,\n  \"sizes\": [\"Small\", \"Medium\", \"Large\"],\n  \"stock_status\": true,\n  \"rating\": 4.5,\n  \"reviews_count\": 10,\n  \"tags\": [\"BESTSELLER\"]\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Aurora Frame (Updated)\",\n  \"price\": 54.99\n}"
            },
            "url": "{{baseUrl}}/api/products/1"
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/products/1"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/categories"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-session-id", "value": "{{sessionId}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cart?session_id={{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"],
              "query": [{ "key": "session_id", "value": "{{sessionId}}" }]
            }
          }
        },
        {
          "name": "Add to cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-id", "value": "{{sessionId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 2,\n  \"size\": \"Medium\"\n}"
            },
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Update cart item",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3,\n  \"size\": \"Large\"\n}"
            },
            "url": "{{baseUrl}}/api/cart/1"
          }
        },
        {
          "name": "Remove from cart",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/cart/1"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create order from cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-id", "value": "{{sessionId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{sessionId}}\",\n  \"user_id\": 1\n}"
            },
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Get order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/orders/1"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Pay order (demo)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": 1,\n  \"amount\": 99.98,\n  \"demo_last4\": \"4242\",\n  \"demo_brand\": \"visa\"\n}"
            },
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "Get payments for order",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/payments/order/1"
          }
        }
      ]
    },
    {
      "name": "Suggestions",
      "item": [
        {
          "name": "Submit suggestion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"anime\",\n  \"title\": \"One Piece frame\",\n  \"description\": \"Would love a frame with Luffy and crew\"\n}"
            },
            "url": "{{baseUrl}}/api/suggestions"
          }
        }
      ]
    },
    {
      "name": "Newsletter",
      "item": [
        {
          "name": "Subscribe to newsletter",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/newsletter"
          }
        }
      ]
    }
  ]
}
